{
  "expo": {
    "name": "courier-tracker",
    "slug": "courier-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "couriertracker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.denilsonsilva97.couriertracker",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Permita que o RotaPro acesse sua localização para rastrear suas rotas de entrega, mesmo em segundo plano.",
        "NSLocationWhenInUseUsageDescription": "O RotaPro precisa da sua localização para registrar seus percursos durante o trabalho.",
        "NSLocationAlwaysUsageDescription": "O rastreamento em segundo plano é necessário para calcular a distância percorrida automaticamente.",
        "NSMotionUsageDescription": "Usamos sensores de movimento para otimizar o consumo de bateria durante o rastreamento.",
        "UIBackgroundModes": ["location", "fetch", "remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.denilsonsilva97.couriertracker",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.WAKE_LOCK"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyB65tsLJnASpfjERg1DduQGq8SPkDWwIP8"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-task-manager",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#007AFF"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysPermission": "Permitir que o app acesse sua localização mesmo quando estiver em segundo plano.",
          "locationWhenInUsePermission": "Permitir que o app acesse sua localização para calcular rotas.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "foregroundService": {
            "notificationTitle": "RotaPro - Rastreamento Ativo",
            "notificationBody": "O RotaPro está registrando seu percurso.",
            "notificationIcon": "./assets/images/icon.png"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2174b271-8545-44cc-9bac-cc3fbe8d135c"
      }
    }
  }
}
